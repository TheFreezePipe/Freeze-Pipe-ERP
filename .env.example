# =============================================================================
# Freeze Pipe ERP — Environment Variables
# =============================================================================
# Copy to .env.local and fill in real values. NEVER commit a real .env file.
#
# Variables prefixed with VITE_ are bundled into the browser (safe for public
# values only). Everything else is server-side — set as Supabase Edge Function
# secrets via `supabase secrets set NAME=value --project-ref <ref>`.
#
# Three environments: dev / staging / prod. Each gets its own Supabase project
# and its own values. See docs/ENVIRONMENTS.md.
# =============================================================================


# -----------------------------------------------------------------------------
# Frontend: Supabase project (REQUIRED)
# -----------------------------------------------------------------------------
# From Supabase dashboard: Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxx

# Current environment name. Shown as a banner on non-prod.
# Values: dev | staging | prod
VITE_APP_ENV=dev


# -----------------------------------------------------------------------------
# Frontend: Observability (optional until go-live, required for prod)
# -----------------------------------------------------------------------------
# Sentry DSN per environment. From app.sentry.io → Settings → Projects → DSN.
VITE_SENTRY_DSN=

# PostHog product analytics. From app.posthog.com → Settings → Project.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com


# =============================================================================
# SERVER-SIDE ONLY — never prefix with VITE_, never commit, never bundle.
# Set these as Supabase Edge Function secrets:
#
#   supabase secrets set \
#     SHIPSTATION_API_KEY="..." \
#     SHIPSTATION_API_SECRET="..." \
#     --project-ref <project-ref>
# =============================================================================


# -----------------------------------------------------------------------------
# Supabase service role — for Edge Functions and backfill scripts only
# -----------------------------------------------------------------------------
# From Supabase dashboard: Settings → API → service_role secret.
# Bypasses RLS — treat like a database password. NEVER ship to the browser.
SUPABASE_SERVICE_ROLE_KEY=


# -----------------------------------------------------------------------------
# ShipStation integration
# -----------------------------------------------------------------------------
# From ShipStation: Settings → Account → API Settings → Generate New API Keys
SHIPSTATION_API_KEY=
SHIPSTATION_API_SECRET=

# Random 32+ char string. Used as the ?s= query param on the webhook URL
# to authenticate ShipStation's callbacks. Generate with:
#   openssl rand -hex 32
SHIPSTATION_WEBHOOK_SECRET=

# Optional: comma-separated ShipStation IP ranges for an additional
# allowlist on the webhook receiver. Leave empty to skip IP checks.
SHIPSTATION_IP_ALLOWLIST=


# -----------------------------------------------------------------------------
# Homebase integration (labor hours for Tasks/Hr on the Performance page)
# -----------------------------------------------------------------------------
# From Homebase: Settings → API → Generate Token
HOMEBASE_API_KEY=

# The Homebase location id. Check their API docs or UI for your location's id.
HOMEBASE_LOCATION_ID=


# -----------------------------------------------------------------------------
# Carrier tracking APIs (for the tracking-reconcile Edge Function)
# -----------------------------------------------------------------------------
# Maersk — https://developer.maersk.com/api-catalogue/track-and-trace
MAERSK_API_KEY=

# FedEx — https://developer.fedex.com (OAuth2 client credentials)
FEDEX_API_KEY=
FEDEX_API_SECRET=

# DHL — https://developer.dhl.com/api-reference/shipment-tracking
DHL_API_KEY=

# COSCO + Evergreen have no standard public API. Use a unified tracker like
# Project44 or AfterShip if you need real-time for those carriers.
# Leave these blank and the reconciler falls back to 'not_received' status
# for unsupported carriers (safe default; no false data).


# -----------------------------------------------------------------------------
# pg_cron configuration (set once per Supabase project via SQL Editor)
# -----------------------------------------------------------------------------
# These are set in the DB, not in .env. Documented here so the full
# configuration lives in one place. In the Supabase SQL Editor run:
#
#   ALTER DATABASE postgres SET app.settings.project_url
#     TO 'https://<project-ref>.supabase.co';
#   ALTER DATABASE postgres SET app.settings.service_role_jwt
#     TO '<service-role-jwt-value>';
#
# Then migration 016 (tracking_cron) schedules the periodic jobs.
